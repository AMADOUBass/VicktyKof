# =============================================
# VicktyKof — Environment Variables
# Copy this file to .env.local and fill values
# =============================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/vicktykof"

# NextAuth
AUTH_SECRET="your-secret-here-min-32-chars"
AUTH_URL="http://localhost:3000"

# Google OAuth (optional)
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_DEPOSIT_PERCENT=30

# Email (SMTP via Gmail or Resend)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="vicktykoff@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="VicktyKof <vicktykoff@gmail.com>"

# UploadThing (file uploads)
UPLOADTHING_SECRET="sk_live_..."
UPLOADTHING_APP_ID="your-app-id"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
